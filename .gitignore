/target
**/*.rs.bk
*.pdb

# Note: Cargo.lock is intentionally NOT ignored — commit it for binaries/apps.

# Solved sims can get large; ignore the cache dir, ship a curated set elsewhere.
/sims_cache

# Only the starter-8 curated library is committed (design 02); bigger tiers
# regenerate locally via `solve-gen gen --manifest`. Already-tracked starter-8
# files are unaffected; `git add -f` if that curated set ever grows.
/data/solutions/*.json

# Preflop charts (design 07): header.json + starter.jsonl per ruleset ARE
# committed; the full export regenerates locally via `preflop-gen gen`.
# Never commit a custom (non-manifest) ruleset directory.
/data/preflop/*/charts.jsonl

# Reach-pruned postflop tables (solve-gen tables): an offline optimization for
# `drill hand` / `table` — the live-solve fallback covers a fresh clone, so
# nothing here is committed (same stance as data/solutions). Regenerate locally.
# No trailing slash: data/tables may be a symlink onto the bulk-storage HDD
# (design doc 08), and dir-only patterns don't match symlinks.
# NOTE: data/tables-web/ (the thin flop-only web export, `poker-trainer
# export-tables-web`) IS committed and deployed — deliberately not ignored.
/data/tables

# web/ is its own workspace; pkg/ is wasm-pack output, solutions/, preflop/
# and tables/ are local stages (symlinks into data/).
/web/target
/web/pkg
/web/solutions
/web/preflop
/web/tables
